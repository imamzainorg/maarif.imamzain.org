---
/** Full single-page composition, shared by all three locale routes. */
import { type Locale } from '@/site.config';
import { CONTENT } from '@/i18n/content';
import { screensFor } from '@/lib/screens';
import Header from './Header.astro';
import Hero from './Hero.astro';
import TrustBar from './TrustBar.astro';
import Showcase from './Showcase.astro';
import ContentSection from './ContentSection.astro';
import LiteratureBand from './LiteratureBand.astro';
import FeatureGrid from './FeatureGrid.astro';
import Faq from './Faq.astro';
import CtaBand from './CtaBand.astro';
import Footer from './Footer.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = CONTENT[locale];
const screens = screensFor(locale);
const byId = Object.fromEntries(c.sections.map((s) => [s.id, s]));
const rights = byId.rights;
const recitations = byId.recitations;
const competition = byId.competition;
const journey = byId.journey;
---
<Header locale={locale} />
<main id="main" tabindex="-1">
  <Hero locale={locale} />
  <TrustBar locale={locale} />
  <Showcase locale={locale} />

  <ContentSection
    eyebrow={rights.eyebrow} title={rights.title} body={rights.body}
    icon="scroll" image={screens.rights} alt={c.alt.rightsPhone}
  />
  <ContentSection
    eyebrow={recitations.eyebrow} title={recitations.title} body={recitations.body}
    icon="headphones" image={screens.recitations} alt={c.alt.recitationsPhone}
    reversed tint
  />
  <ContentSection
    eyebrow={competition.eyebrow} title={competition.title} body={competition.body}
    icon="trophy" image={screens.competition} alt={c.alt.competitionPhone}
    warm
  />

  <LiteratureBand eyebrow={journey.eyebrow} title={journey.title} body={journey.body} />

  <FeatureGrid locale={locale} />
  <Faq locale={locale} />
  <CtaBand locale={locale} />
</main>
<Footer locale={locale} />
