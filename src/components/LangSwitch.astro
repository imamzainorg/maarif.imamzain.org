---
/** Language switcher — plain anchor links, zero JS. Marks the active locale.
 *  By default links between the locale home pages; pass `paths` to switch
 *  between localized variants of another page (e.g. the privacy policy). */
import { SITE, type Locale } from '@/site.config';
import { localePath, LOCALE_LABEL, HTML_LANG } from '@/i18n';

interface Props {
  locale: Locale;
  paths?: Record<Locale, string>;
}
const { locale, paths } = Astro.props;
---
<nav class="lang" aria-label="Language">
  {SITE.locales.map((l) => (
    <a
      href={paths ? paths[l] : localePath(l)}
      lang={HTML_LANG[l]}
      hreflang={HTML_LANG[l]}
      aria-current={l === locale ? 'true' : undefined}
    >{LOCALE_LABEL[l]}</a>
  ))}
</nav>
