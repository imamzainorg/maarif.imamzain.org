---
/**
 * Account & data deletion request page — one component, three locales
 * (`/delete-account`, `/en/delete-account`, `/fa/delete-account`).
 *
 * The Arabic URL is the one submitted to Google Play's Data safety form, which
 * requires a page a user can reach — and act on — without installing the app or
 * signing in. Hence: no auth, indexable, and a prefilled mailto to
 * `SITE.contact.email` as the request mechanism. The address is also printed as
 * selectable text, so the page still works where `mailto:` has no handler.
 */
import "@fontsource-variable/vazirmatn/index.css"
import "@/styles/global.css"
import { SITE, type Locale } from "@/site.config"
import {
	DIR,
	HTML_LANG,
	localePath,
	privacyPath,
	deleteAccountPath,
	deleteAccountAlternates,
} from "@/i18n"
import { DELETE_ACCOUNT_CONTENT } from "@/i18n/delete-account"
import { ogLocale } from "@/lib/jsonld"
import Logo from "@/components/Logo.astro"
import LangSwitch from "@/components/LangSwitch.astro"
import Footer from "@/components/Footer.astro"
import Icon from "@/components/Icon.astro"

interface Props {
	locale: Locale
}
const { locale } = Astro.props
const c = DELETE_ACCOUNT_CONTENT[locale]

const canonical = `${SITE.origin}${deleteAccountPath(locale)}`
const homeHref = localePath(locale)
const alts = deleteAccountAlternates()
const langPaths = Object.fromEntries(
	SITE.locales.map((l) => [l, deleteAccountPath(l)]),
) as Record<Locale, string>
const brandName =
	locale === "en"
		? "Maarif Sajjadiya"
		: locale === "fa"
			? "معارف سجادیه"
			: "معارف سجادية"
const brandLatin = locale === "en" ? "معارف سجادية" : "Maarif Sajjadiya"

/** The request itself: opens the user's mail app with everything already
 *  written except the name and phone number that identify their account. */
const mailto = `mailto:${SITE.contact.email}?subject=${encodeURIComponent(
	c.byEmail.subject,
)}&body=${encodeURIComponent(c.byEmail.body)}`
---

<!doctype html>
<html lang={HTML_LANG[locale]} dir={DIR[locale]}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.png" type="image/png" sizes="64x64" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<title>{c.seo.title}</title>
		<meta name="description" content={c.seo.description} />
		<link rel="canonical" href={canonical} />
		{
			alts.map((a) => (
				<link rel="alternate" hreflang={a.hreflang} href={a.href} />
			))
		}
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<meta name="theme-color" content={SITE.brand.primary} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={c.seo.title} />
		<meta property="og:description" content={c.seo.description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:locale" content={ogLocale(locale)} />
	</head>
	<body class="da">
		<a href="#main" class="skip-link">{c.skip}</a>
		<span id="top"></span>

		<header class="site-header">
			<div class="wrap site-header__row">
				<a class="brand" href={homeHref} aria-label={brandName}>
					<Logo class="brand__mark" size={38} title={brandName} />
					<span class="brand__name"
						>{brandName}<small>{brandLatin}</small></span
					>
				</a>
				<div class="header-actions">
					<LangSwitch locale={locale} paths={langPaths} />
					<a class="btn btn--ghost btn--sm da-back" href={homeHref}>
						<Icon name="arrow-right" size={16} />
						{c.back}
					</a>
				</div>
			</div>
		</header>

		<main id="main" tabindex="-1">
			<section class="wrap da-hero">
				<span class="da-badge"
					><Icon name="delete" size={16} /> {c.badge}</span
				>
				<h1 class="da-title">{c.heading}</h1>
				<div class="da-rule"><span></span><i></i><span></span></div>
				<p class="da-lead">{c.lead}</p>
			</section>

			<section class="wrap">
				<div class="da-cards">
					<article class="da-card">
						<header class="da-card__head">
							<span class="da-ic">
								<Icon name="smartphone" size={22} />
							</span>
							<div>
								<span class="da-order">{c.inApp.order}</span>
								<h2>{c.inApp.title}</h2>
							</div>
						</header>
						<p class="da-note">{c.inApp.note}</p>
						<ol class="da-steps">
							{c.inApp.steps.map((s) => <li>{s}</li>)}
						</ol>
					</article>

					<article class="da-card da-card--mail" id="email">
						<header class="da-card__head">
							<span class="da-ic da-ic--gold">
								<Icon name="mail" size={22} />
							</span>
							<div>
								<span class="da-order">{c.byEmail.order}</span>
								<h2>{c.byEmail.title}</h2>
							</div>
						</header>
						<p class="da-note">{c.byEmail.note}</p>
						<a class="btn btn--primary da-mail" href={mailto}>
							<Icon name="mail" size={18} />
							{c.byEmail.cta}
						</a>
						<p class="da-fallback">
							{c.byEmail.fallback}{" "}
							<a href={`mailto:${SITE.contact.email}`}
								>{SITE.contact.email}</a
							>
						</p>
					</article>

					<article class="da-card">
						<header class="da-card__head">
							<span class="da-ic">
								<Icon name="list-checks" size={22} />
							</span>
							<div><h2>{c.scope.title}</h2></div>
						</header>
						<ul class="da-points">
							{c.scope.items.map((p) => <li>{p}</li>)}
						</ul>
					</article>

					<article class="da-card">
						<header class="da-card__head">
							<span class="da-ic">
								<Icon name="clock" size={22} />
							</span>
							<div><h2>{c.timing.title}</h2></div>
						</header>
						<ul class="da-points">
							{c.timing.items.map((p) => <li>{p}</li>)}
						</ul>
					</article>
				</div>
			</section>

			<section class="wrap">
				<div class="da-band">
					<Icon name="shield-check" size={40} class="da-band__ic" />
					<h2>{c.band.title}</h2>
					<p>{c.band.body}</p>
					<div class="da-actions">
						<a class="btn btn--primary" href={privacyPath(locale)}
							>{c.band.privacy}</a
						>
						<a class="btn btn--on-dark btn--ghost" href={homeHref}
							>{c.band.home}</a
						>
					</div>
				</div>
			</section>

			<section class="wrap da-foot">
				<span class="da-foot__name"
					><Icon name="sparkle" size={16} /> {c.foot.name}</span
				>
				<p>{c.foot.note}</p>
			</section>
		</main>

		<Footer locale={locale} />

		<style>
			.da {
				background: var(--paper);
			}
			.da-hero {
				text-align: center;
				padding-block: clamp(2rem, 5vw, 3.5rem)
					clamp(1.4rem, 4vw, 2.2rem);
			}
			.da-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.4rem 1rem;
				border-radius: 999px;
				border: 1px solid
					color-mix(in srgb, var(--gold) 40%, transparent);
				background: color-mix(in srgb, var(--gold) 12%, transparent);
				color: var(--gold-600);
				font-weight: 700;
				font-size: var(--step--1);
			}
			.da-badge svg {
				inline-size: 1rem;
				block-size: 1rem;
			}
			.da-title {
				font-size: var(--step-3);
				margin-block: 1rem 0.8rem;
				color: var(--teal-900);
			}
			@media (prefers-color-scheme: dark) {
				.da-title {
					color: var(--ink);
				}
			}
			.da-rule {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.6rem;
				margin-block: 0.4rem 1.2rem;
			}
			.da-rule span {
				inline-size: 3rem;
				block-size: 1px;
				background: color-mix(in srgb, var(--gold) 55%, transparent);
			}
			.da-rule i {
				inline-size: 0.4rem;
				block-size: 0.4rem;
				border-radius: 999px;
				background: var(--gold);
			}
			.da-lead {
				color: var(--muted);
				font-size: var(--step-1);
				max-inline-size: 42rem;
				margin-inline: auto;
				font-weight: 500;
			}

			.da-cards {
				max-inline-size: 48rem;
				margin-inline: auto;
				display: grid;
				gap: 1.2rem;
			}
			.da-card {
				background: var(--card);
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				padding: clamp(1.4rem, 4vw, 2.4rem);
				box-shadow: var(--shadow-sm);
			}
			/* The email route is the one Google Play's reviewers follow — give it
			   the accent border so it reads as the page's primary action. */
			.da-card--mail {
				border-color: color-mix(in srgb, var(--gold) 45%, var(--line));
			}
			.da-card__head {
				display: flex;
				align-items: center;
				gap: 1rem;
				padding-block-end: 1.1rem;
				border-block-end: 1px solid var(--line);
				margin-block-end: 1.2rem;
			}
			.da-ic {
				flex: none;
				inline-size: 3rem;
				block-size: 3rem;
				display: grid;
				place-items: center;
				border-radius: 999px;
				background: var(--mint);
				color: var(--teal-800);
			}
			.da-ic--gold {
				background: color-mix(in srgb, var(--gold) 22%, transparent);
				color: var(--gold-600);
			}
			@media (prefers-color-scheme: dark) {
				.da-ic {
					color: var(--mint);
					background: rgba(200, 224, 224, 0.14);
				}
				.da-ic--gold {
					color: var(--gold-200);
					background: color-mix(in srgb, var(--gold) 26%, transparent);
				}
			}
			.da-order {
				display: block;
				font-size: var(--step--1);
				font-weight: 700;
				color: var(--gold-600);
			}
			.da-card h2 {
				font-size: var(--step-1);
				color: var(--ink);
				margin-block-start: 0.15rem;
			}
			.da-note {
				color: var(--muted);
				line-height: 1.75;
			}

			.da-steps {
				list-style: none;
				counter-reset: step;
				padding: 0;
				display: grid;
				gap: 0.9rem;
				margin-block-start: 1.3rem;
			}
			.da-steps li {
				counter-increment: step;
				display: flex;
				gap: 0.8rem;
				align-items: center;
				color: var(--ink);
				font-weight: 500;
			}
			.da-steps li::before {
				content: counter(step);
				flex: none;
				inline-size: 1.8rem;
				block-size: 1.8rem;
				display: grid;
				place-items: center;
				border-radius: 999px;
				background: var(--mint);
				color: var(--teal-800);
				font-size: var(--step--1);
				font-weight: 800;
			}
			@media (prefers-color-scheme: dark) {
				.da-steps li::before {
					background: rgba(200, 224, 224, 0.14);
					color: var(--mint);
				}
			}

			.da-mail {
				margin-block-start: 1.5rem;
				white-space: normal;
			}
			.da-fallback {
				margin-block-start: 1rem;
				color: var(--muted);
				font-size: var(--step--1);
			}
			.da-fallback a {
				color: var(--teal-600);
				font-weight: 700;
				text-decoration: underline;
				text-underline-offset: 3px;
				word-break: break-word;
			}
			@media (prefers-color-scheme: dark) {
				.da-fallback a {
					color: var(--mint-300);
				}
			}

			.da-points {
				list-style: none;
				padding: 0;
				display: grid;
				gap: 0.95rem;
			}
			.da-points li {
				display: flex;
				gap: 0.7rem;
				align-items: flex-start;
				color: var(--muted);
				line-height: 1.75;
			}
			.da-points li::before {
				content: "";
				flex: none;
				inline-size: 0.5rem;
				block-size: 0.5rem;
				border-radius: 999px;
				background: var(--gold);
				margin-block-start: 0.65rem;
			}

			.da-band {
				position: relative;
				overflow: hidden;
				text-align: center;
				color: #f2f8f6;
				background: linear-gradient(
					160deg,
					var(--teal-700),
					var(--teal-900)
				);
				border-radius: var(--radius-lg);
				padding: clamp(2rem, 5vw, 3.5rem);
				margin-block: clamp(2rem, 5vw, 3rem);
				box-shadow: var(--shadow-md);
			}
			.da-band__ic {
				color: var(--gold-200);
				margin-inline: auto;
			}
			.da-band h2 {
				font-size: var(--step-2);
				margin-block-start: 0.6rem;
			}
			.da-band p {
				color: rgba(240, 248, 246, 0.9);
				max-inline-size: 36rem;
				margin: 1rem auto 1.6rem;
			}
			.da-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				justify-content: center;
			}

			.da-foot {
				text-align: center;
				padding-block: 1rem 3rem;
			}
			.da-foot__name {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--gold-600);
				font-weight: 700;
			}
			.da-foot p {
				color: var(--muted);
				font-size: var(--step--1);
				margin-block-start: 0.5rem;
				max-inline-size: 30rem;
				margin-inline: auto;
			}

			/* Keep the compact header usable on phones: the back button yields first. */
			@media (max-width: 560px) {
				.da-back {
					display: none;
				}
			}
		</style>
	</body>
</html>
