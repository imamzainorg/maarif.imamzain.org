---
import { SITE, type Locale } from "@/site.config"
import { CONTENT } from "@/i18n/content"
import { deleteAccountPath, privacyPath } from "@/i18n"
import Logo from "./Logo.astro"
import LangSwitch from "./LangSwitch.astro"

interface Props {
	locale: Locale
}
const { locale } = Astro.props
const c = CONTENT[locale]
const year = new Date()
	.toLocaleDateString("en-US-u-ca-islamic-umalqura", {
		year: "numeric",
	})
	.replace("AH", "هجرية")

/** Pre-launch: render store links as muted "coming soon" chips, not dead links. */
const isLive = (url: string | null) =>
	SITE.launch.live && typeof url === "string" && url.length > 0
const PRIVACY: Record<Locale, string> = {
	ar: "سياسة الخصوصية",
	en: "Privacy Policy",
	fa: "سیاست حریم خصوصی",
}
/** Google Play expects the deletion route to be reachable from the site. */
const DELETE: Record<Locale, string> = {
	ar: "حذف الحساب",
	en: "Delete account",
	fa: "حذف حساب",
}
---

<footer class="site-footer">
	<div class="wrap">
		<div class="site-footer__top">
			<div>
				<a class="brand" href="#top" aria-label={c.brand.name}>
					<Logo class="brand__mark" size={40} />
					<span class="brand__name"
						>{c.brand.name}<small>{c.brand.nameLatin}</small></span
					>
				</a>
				<p class="site-footer__tag">{c.footer.tagline}</p>
			</div>
			<div class="site-footer__links">
				{
					isLive(SITE.stores.ios) ? (
						<a
							class="btn btn--on-dark btn--ghost btn--sm"
							href={SITE.stores.ios}
							target="_blank"
							rel="noopener noreferrer"
						>
							App Store
						</a>
					) : (
						<span
							class="btn btn--on-dark btn--ghost btn--sm is-soon"
							aria-disabled="true"
						>
							App Store · {c.footer.comingSoon}
						</span>
					)
				}
				{
					isLive(SITE.stores.android) ? (
						<a
							class="btn btn--on-dark btn--ghost btn--sm"
							href={SITE.stores.android}
							target="_blank"
							rel="noopener noreferrer"
						>
							Google Play
						</a>
					) : (
						<span
							class="btn btn--on-dark btn--ghost btn--sm is-soon"
							aria-disabled="true"
						>
							Google Play · {c.footer.comingSoon}
						</span>
					)
				}
				<a
					class="btn btn--on-dark btn--ghost btn--sm"
					href={SITE.org.url}
					target="_blank"
					rel="noopener noreferrer">imamzain.org</a
				>
			</div>
		</div>
		<div class="site-footer__bottom">
			<span>© {year} · {c.footer.rights}</span>
			<nav class="site-footer__legal">
				<a href={privacyPath(locale)}>{PRIVACY[locale]}</a>
				<a href={deleteAccountPath(locale)}>{DELETE[locale]}</a>
			</nav>
			<LangSwitch locale={locale} />
		</div>
	</div>
</footer>
