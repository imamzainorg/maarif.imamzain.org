---
import { type Locale } from '@/site.config';
import { CONTENT } from '@/i18n/content';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = CONTENT[locale];

const ICONS: Record<string, string> = {
  offline: 'wifi-off',
  gps: 'navigation',
  audio: 'headphones',
  notifications: 'bell',
  trilingual: 'globe',
  progress: 'list-checks',
};
---
<section class="section" id="features">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow"><Icon name="sparkle" size={16} /> {c.brand.name}</span>
      <h2 class="section-title">{c.featuresHeading.title}</h2>
      <p class="lead">{c.featuresHeading.subtitle}</p>
    </div>

    <div class="feature-grid">
      {c.features.map((f) => (
        <article class="feature reveal">
          <span class="feature__ic"><Icon name={ICONS[f.id] ?? 'sparkle'} /></span>
          <h3>{f.title}</h3>
          <p>{f.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
