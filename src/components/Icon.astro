}

const isFill = name in FILL
const body = isFill ? FILL[name] : STROKE[name]
---

{
	isFill ? (
		<svg
			class={klass}
			width={size}
			height={size}
			viewBox="0 0 24 24"
			fill="currentColor"
			aria-hidden="true"
			set:html={body}
		/>
	) : (
		<svg
			class={klass}
			width={size}
			height={size}
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.8"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
			set:html={body}
		/>
	)
}
