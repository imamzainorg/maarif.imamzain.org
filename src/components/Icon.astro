---
/**
 * Inline SVG icon set. Line icons (stroke) for UI/features; two filled glyphs
 * for the store badges. Everything inlined — no icon-font, no image requests.
 */
interface Props {
	name: string
	class?: string
	size?: number
}
const { name, class: klass, size = 24 } = Astro.props

