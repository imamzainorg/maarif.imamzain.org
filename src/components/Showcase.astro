---
/** The Stations & Adhkar showcase - the flagship module: the route split into
 *  ordered stations along numbered poles, each with its own adhkar/du'as. */
import { type Locale } from "@/site.config"
import { CONTENT } from "@/i18n/content"
import { screensFor } from "@/lib/screens"
import PhoneFrame from "./PhoneFrame.astro"
import Icon from "./Icon.astro"

interface Props {
	locale: Locale
}
const { locale } = Astro.props
const c = CONTENT[locale]
const screens = screensFor(locale)
---

<section class="section" id="content">
	<div class="wrap split">
		<div class="split__media reveal">
			<div class="media-card">
				<div class="pattern"></div>
				<PhoneFrame
					image={screens.stations}
					alt={c.alt.stationsPhone}
					sizes="(max-width: 900px) 58vw, 250px"
				/>
			</div>
		</div>
		<div class="split__copy reveal">
			<span class="eyebrow"
				><Icon name="map-pin" size={16} /> {c.showcase.eyebrow}</span
			>
			<h2 class="section-title">{c.showcase.title}</h2>
			<p class="lead">{c.showcase.lead}</p>
			<ul class="checklist">
				{
					c.showcase.bullets.map((b) => (
						<li>
							<Icon name="check" /> <span>{b}</span>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
