---
/**
 * A QR code rendered from a static SVG file.
 */
import qrSvg from "@/assets/qr.svg?raw"
import { type Locale } from "@/site.config"

interface Props {
	locale: Locale
	caption?: string
}
const { caption } = Astro.props
---

<figure class="qr">
	<div set:html={qrSvg} aria-hidden="true" />
	{caption && <figcaption class="qr__cap">{caption}</figcaption>}
</figure>
