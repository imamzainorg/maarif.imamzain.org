---
/**
 * A QR code rendered to inline SVG AT BUILD TIME (no client JS, no image
 * request). It encodes this locale's URL with ?go=1 so that when a desktop
 * visitor scans it with their phone, the head script forwards them straight to
 * the correct store.
 */
import QRCode from 'qrcode';
import { SITE, type Locale } from '@/site.config';
import { localePath } from '@/i18n';

interface Props {
  locale: Locale;
  caption?: string;
}
const { locale, caption } = Astro.props;

const target = `${SITE.origin}${localePath(locale)}?go=1`;
const svg = await QRCode.toString(target, {
  type: 'svg',
  margin: 0,
  errorCorrectionLevel: 'M',
  color: { dark: SITE.brand.primary, light: '#00000000' },
});
---
<figure class="qr">
  <div set:html={svg} aria-hidden="true"></div>
  {caption && <figcaption class="qr__cap">{caption}</figcaption>}
</figure>
