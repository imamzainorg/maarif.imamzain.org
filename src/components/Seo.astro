---
/**
 * Everything that lives in <head> for SEO: title, description, canonical,
 * hreflang alternates, Open Graph + Twitter cards, iOS smart-app banner and
 * JSON-LD structured data.
 */
import { SITE, type Locale } from "@/site.config"
import { CONTENT } from "@/i18n/content"
import { canonicalUrl, alternates, HTML_LANG } from "@/i18n"
import { buildJsonLd, ogLocale } from "@/lib/jsonld"

interface Props {
	locale: Locale
}
const { locale } = Astro.props
const content = CONTENT[locale]

const canonical = canonicalUrl(locale)
const ogImage = `${SITE.origin}/og/${locale}.jpg`
const alts = alternates()
const jsonld = buildJsonLd({ content, url: canonical, ogImage })
const otherLocales = SITE.locales.filter((l) => l !== locale)
---

<title>{content.seo.title}</title>
<meta name="description" content={content.seo.description} />
<meta name="keywords" content={content.seo.keywords.join(", ")} />
<meta name="author" content={content.brand.org} />
<meta
	name="robots"
	content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>
<link rel="canonical" href={canonical} />

{/* hreflang alternates for every locale + x-default */}
{alts.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

{
	/* iOS Safari smart app banner - one tap to the App Store. Only once the iOS
    app is actually published (has an App Store id) and live. */
}
{
	SITE.launch.live && SITE.app.iosAppId && (
		<meta name="apple-itunes-app" content={`app-id=${SITE.app.iosAppId}`} />
	)
}

{/* Open Graph */}
<meta property="og:type" content="website" />
<meta property="og:site_name" content={content.brand.name} />
<meta property="og:title" content={content.seo.ogTitle} />
<meta property="og:description" content={content.seo.ogDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={ogLocale(locale)} />
{
	otherLocales.map((l) => (
		<meta property="og:locale:alternate" content={ogLocale(l)} />
	))
}
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={content.seo.ogTitle} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={content.seo.ogTitle} />
<meta name="twitter:description" content={content.seo.ogDescription} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={content.seo.ogTitle} />

<meta name="theme-color" content={SITE.brand.primary} />
<meta name="application-name" content={content.brand.name} />
<meta name="apple-mobile-web-app-title" content={content.brand.name} />

{/* JSON-LD structured data */}
{
	jsonld.map((node) => (
		<script type="application/ld+json" set:html={JSON.stringify(node)} />
	))
}
